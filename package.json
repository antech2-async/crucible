{
  "name": "crucible-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Crucible - AI Agent Coordination Layer for 0G Hackathon",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky install || true",
    "lint": "npm run lint:ts && npm run lint:sol",
    "lint:ts": "eslint packages --ext .ts,.tsx",
    "lint:ts:fix": "eslint packages --ext .ts,.tsx --fix",
    "lint:sol": "solhint \"packages/contracts/contracts/**/*.sol\"",
    "format": "prettier --write \"packages/**/*.{ts,sol,md,json}\"",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e -w @crucible/frontend",
    "test:e2e:headed": "npm run test:e2e:headed -w @crucible/frontend",
    "test:e2e:ui": "npm run test:e2e:ui -w @crucible/frontend",
    "playwright:install": "npm run playwright:install -w @crucible/frontend",
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces"
  },
  "overrides": {
    "axios": "1.16.0",
    "undici": "6.24.0",
    "minimatch": "10.2.5",
    "serialize-javascript": "7.0.5",
    "next": "16.2.3",
    "glob": "13.0.6",
    "tmp": "0.2.5",
    "elliptic": "6.6.1",
    "cookie": "0.7.2",
    "fast-uri": "3.1.2",
    "cross-spawn": "7.0.6",
    "hono": "4.12.16",
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "prettier-plugin-solidity": "^1.3.1",
    "solhint": "^4.1.1",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/contracts/contracts/**/*.sol": [
      "solhint --fix",
      "prettier --write"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {}
}
