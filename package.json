{
  "name": "crucible-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Crucible - AI Agent Coordination Layer for 0G Hackathon",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky install",
    "lint": "npm run lint:ts && npm run lint:sol",
    "lint:ts": "eslint \"packages/**/src/**/*.ts\"",
    "lint:sol": "solhint \"packages/contracts/contracts/**/*.sol\"",
    "format": "prettier --write \"packages/**/*.{ts,sol,md,json}\"",
    "test": "npm run test --workspaces",
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "prettier-plugin-solidity": "^1.3.1",
    "solhint": "^4.1.1",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/contracts/contracts/**/*.sol": [
      "solhint --fix",
      "prettier --write"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
  }
}
