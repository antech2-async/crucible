{
  "compilerOptions": {
    "target": "es2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "esModuleInterop": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@crucible/shared": ["../shared/src/index.ts"],
      "@crucible/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["./src", "./scripts", "../contracts/artifacts/**/*"]
}
