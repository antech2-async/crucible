# 0G Network configuration
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
OG_STORAGE_INDEXER_URL=https://indexer-testnet.0g.ai

# Wallet - MUST BE 0x... format
# DO NOT COMMIT YOUR ACTUAL PRIVATE KEY
PRIVATE_KEY=your_private_key_here

# 0G Compute Provider
OG_COMPUTE_PROVIDER_ADDRESS=0x0000000000000000000000000000000000000000
OG_MODEL=qwen-2.5-7b-instruct

# Log Level: trace, debug, info, warn, error
LOG_LEVEL=info
NODE_ENV=development
